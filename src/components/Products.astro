---
import { siteData } from '../data/site.ts';

const extraSolutionLinks = [
  {
    label: 'Site para Guias e Motoristas de App',
    href: '/mot-app',
    icon: '🚗',
    description: 'Página comercial pensada para guias e motoristas divulgarem roteiros, parceiros e contatos em um só lugar.',
    features: [
      'Links de afiliados e indicações',
      'Compartilhamento rápido pelo WhatsApp',
      'Estrutura comercial para gerar contatos'
    ]
  },
  {
    label: 'Site para Influencers',
    href: '/influencer',
    icon: '🎥',
    description: 'Hub profissional para creators centralizarem campanhas, parceiros, cupons e monetização da audiência.',
    features: [
      'Centralização de todos os links',
      'Página pronta para parcerias e publis',
      'Mais autoridade para vender mídia e afiliados'
    ]
  },
  {
    label: 'Site para Casa por Temporada',
    href: '/casa-temporada',
    icon: '🏡',
    description: 'Site próprio para aumentar reservas, apresentar o imóvel com mais valor e facilitar o contato direto com o hóspede.',
    features: [
      'Mais reservas sem depender só de marketplaces',
      'Apresentação completa do imóvel',
      'Contato direto e rápido com o visitante'
    ]
  }
];
---

<section id="solucoes" class="py-16 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div id="produtos" class="relative -top-24"></div>

    <div class="text-center max-w-3xl mx-auto mb-14 lg:mb-16">
      <span class="inline-block px-4 py-2 bg-primary-blue/10 text-primary-blue font-semibold rounded-full text-sm mb-4">
        Nossas Soluções
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-dark mb-6 leading-tight">
        Produtos que <span class="text-primary-blue">revolucionam o turismo</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Tecnologias integradas que criam experiências únicas e geram resultados mensuráveis para destinos turísticos de todos os tamanhos.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {siteData.products.map((product) => (
        <article class={`relative h-full rounded-[28px] border p-8 lg:p-10 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl ${product.isPopular ? 'border-primary-blue bg-gradient-to-br from-primary-blue/5 via-white to-accent-amber/10' : 'border-gray-200 bg-neutral-light'}`}>
          {product.isPopular && (
            <div class="absolute right-6 top-6 inline-flex items-center gap-2 rounded-full bg-accent-amber px-4 py-2 text-xs font-bold uppercase tracking-wide text-neutral-dark shadow-md">
              <span>★</span>
              <span>Mais Popular</span>
            </div>
          )}

          <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-blue text-3xl text-white shadow-lg">
            {product.icon}
          </div>
          <h3 class="pr-20 text-2xl font-bold text-neutral-dark leading-tight mb-4">{product.title}</h3>
          <p class="text-gray-600 leading-relaxed mb-6 min-h-[96px]">
            {product.description}
          </p>

          <div class="rounded-2xl bg-white/80 p-5 border border-gray-100 mb-8">
            <p class="text-sm font-semibold uppercase tracking-wide text-primary-blue mb-4">
              Principais Recursos
            </p>
            <ul class="space-y-3">
              {product.features.map((feature) => (
                <li class="flex items-start gap-3 text-gray-700">
                  <div class="mt-1 flex h-5 w-5 items-center justify-center rounded-full bg-primary-green text-white flex-shrink-0">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <a
            href={product.href ?? '#contato'}
            target={product.href?.startsWith('http') ? '_blank' : undefined}
            rel={product.href?.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="inline-flex items-center justify-center w-full sm:w-auto px-6 py-3.5 bg-primary-blue hover:bg-primary-darkblue text-white font-bold rounded-2xl transition-colors duration-200 shadow-lg"
          >
            Saiba Mais
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <div class="mt-10">
      <div class="mb-8 text-center max-w-3xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-wide text-primary-blue">Outras Soluções</p>
        <h3 class="mt-2 text-2xl lg:text-3xl font-bold text-neutral-dark">Páginas específicas para o trade turístico</h3>
        <p class="mt-3 text-gray-600">
          Soluções comerciais no mesmo padrão visual para nichos que precisam vender mais e facilitar o acesso do visitante.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8">
        {extraSolutionLinks.map((link) => (
          <article class="relative h-full rounded-[28px] border border-gray-200 bg-neutral-light p-8 lg:p-10 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
            <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-blue text-3xl text-white shadow-lg">
              {link.icon}
            </div>
            <h4 class="text-2xl font-bold text-neutral-dark leading-tight mb-4">{link.label}</h4>
            <p class="text-gray-600 leading-relaxed mb-6 min-h-[96px]">
              {link.description}
            </p>

            <div class="rounded-2xl bg-white/80 p-5 border border-gray-100 mb-8">
              <p class="text-sm font-semibold uppercase tracking-wide text-primary-blue mb-4">
                Principais Recursos
              </p>
              <ul class="space-y-3">
                {link.features.map((feature) => (
                  <li class="flex items-start gap-3 text-gray-700">
                    <div class="mt-1 flex h-5 w-5 items-center justify-center rounded-full bg-primary-green text-white flex-shrink-0">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                      </svg>
                    </div>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>

            <a
              href={link.href}
              class="inline-flex items-center justify-center w-full sm:w-auto px-6 py-3.5 bg-primary-blue hover:bg-primary-darkblue text-white font-bold rounded-2xl transition-colors duration-200 shadow-lg"
            >
              Saiba Mais
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
